# ──────────────────────────────────────────────────────────────────────────
# Merkert Social Media – Netlify Environment Variables
# Eintragen unter: Netlify Dashboard → merkertsocialmedia.com → Site configuration → Environment variables
# NIEMALS in Git einchecken! Diese Datei ist nur eine Vorlage.
# ──────────────────────────────────────────────────────────────────────────

# Deine Netlify-URL (bereits bekannt)
BASE_URL=https://merkertsocialmedia.com

# Stripe – https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...   # nach Webhook-Erstellung in Stripe eintragen

# Supabase – https://supabase.com/dashboard/project/DEIN-PROJEKT/settings/api
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...       # service_role key (geheim!)

# Bannerbear – https://app.bannerbear.com/projects
BANNERBEAR_API_KEY=bb_...
BB_TEMPLATE_A=TEMPLATE_UID_A
BB_TEMPLATE_B=TEMPLATE_UID_B
BB_TEMPLATE_C=TEMPLATE_UID_C
BB_TEMPLATE_D=TEMPLATE_UID_D
BB_TEMPLATE_E=TEMPLATE_UID_E
BB_TEMPLATE_F=TEMPLATE_UID_F
BB_TEMPLATE_G=TEMPLATE_UID_G

# Resend – https://resend.com/api-keys
RESEND_API_KEY=re_...
